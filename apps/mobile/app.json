{
  "expo": {
    "name": "더블원플러스",
    "slug": "doublewin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "doublewin",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.doublewin.app"
    },
    "android": {
      "package": "com.doublewin.app",
      "adaptiveIcon": {
        "backgroundColor": "#FF6B35",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B35"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "내 주변 학원·어린이집을 보여드리기 위해 위치 정보를 사용합니다."
        }
      ],
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "7822ff27784b8d9481ac9540c79e6d73"
        }
      ],
      [
        "@react-native-seoul/naver-login",
        {
          "urlScheme": "navercomdoublewin"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.726584045345-PLACEHOLDER_IOS"
        }
      ]
    ],
    "extra": {
      "KAKAO_CLIENT_ID": "",
      "NAVER_CLIENT_ID": "",
      "GOOGLE_CLIENT_ID": ""
    }
  }
}
